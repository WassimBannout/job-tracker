{
  "name": "job-tracker-server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "pretest": "DATABASE_URL=\"file:./test.db\" prisma migrate deploy",
    "test": "DATABASE_URL=\"file:./test.db\" NODE_ENV=test node --import tsx --test \"src/**/*.test.ts\""
  },
  "dependencies": {
    "@prisma/adapter-better-sqlite3": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.4.2",
    "express": "^5.1.0",
    "express-session": "^1.19.0",
    "prisma": "^7.8.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/express": "^5.0.3",
    "@types/express-session": "^1.19.0",
    "@types/node": "^24.0.0",
    "@types/supertest": "^7.2.0",
    "supertest": "^7.2.2",
    "tsx": "^4.20.0",
    "typescript": "^5.9.0"
  }
}
